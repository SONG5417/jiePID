 188          //========================================================================
 189          void DisplayRTC(void)
 190          {
 191   1          if(hour >= 10)  LED8[0] = hour / 10;
 192   1          else            LED8[0] = DIS_BLACK;
 193   1          LED8[1] = hour % 10;
 194   1          LED8[2] = DIS_;
 195   1          LED8[3] = minute / 10;
 196   1          LED8[4] = minute % 10;
 197   1          LED8[6] = second / 10;
 198   1          LED8[7] = second % 10;
 199   1      }
 200          
 201          //========================================================================
 202          // КЏЪ§: ReadRTC
 203          // УшЪі: ЖСRTCКЏЪ§.
 204          // ВЮЪ§: None.
 205          // ЗЕЛи: None.
 206          // АцБО: V1.0, 2020-09-25
 207          //========================================================================
 208          void ReadRTC(void)
 209          {
 210   1          u8  tmp[3];
 211   1      
 212   1          I2C_ReadNbyte(2, tmp, 3);
 213   1          second = ((tmp[0] >> 4) & 0x07) * 10 + (tmp[0] & 0x0f);
 214   1          minute = ((tmp[1] >> 4) & 0x07) * 10 + (tmp[1] & 0x0f);
 215   1          hour   = ((tmp[2] >> 4) & 0x03) * 10 + (tmp[2] & 0x0f);
 216   1      }
 217          
 218          //========================================================================
 219          // КЏЪ§: WriteRTC
 220          // УшЪі: аДRTCКЏЪ§.
 221          // ВЮЪ§: None.
 222          // ЗЕЛи: None.
 223          // АцБО: V1.0, 2020-09-25
 224          //========================================================================
 225          void WriteRTC(void)
 226          {
 227   1          u8  tmp[3];
 228   1      
 229   1          tmp[0] = ((second / 10) << 4) + (second % 10);
 230   1          tmp[1] = ((minute / 10) << 4) + (minute % 10);
 231   1          tmp[2] = ((hour / 10) << 4) + (hour % 10);
 232   1          I2C_WriteNbyte(2, tmp, 3);
 233   1      }
