 132          void Sample_RTC(void)
 133          {
 134   1              DisplayScan();
 135   1              
 136   1              if(++msecond >= 1000)   //1УыЕН
 137   1              {
 138   2                      msecond = 0;
 139   2                      ReadRTC();
 140   2                      DisplayRTC();
 141   2              }
 142   1      
 143   1              if(++cnt50ms >= 50)     //50msЩЈУшвЛДЮааСаМќХЬ
 144   1              {
 145   2                      cnt50ms = 0;
 146   2                      IO_KeyScan();
 147   2              }
 148   1              
 149   1              if(KeyCode != 0)        //гаМќАДЯТ
 150   1              {
 151   2                      if(KeyCode == 17)   //hour +1
 152   2                      {
 153   3                              if(++hour >= 24)    hour = 0;
 154   3                              WriteRTC();
 155   3                              DisplayRTC();
 156   3                      }
 157   2                      if(KeyCode == 18)   //hour -1
 158   2                      {
 159   3                              if(--hour >= 24)    hour = 23;
 160   3                              WriteRTC();
 161   3                              DisplayRTC();
 162   3                      }
 163   2                      if(KeyCode == 19)   //minute +1
 164   2                      {
 165   3                              second = 0;
 166   3                              if(++minute >= 60)  minute = 0;
 167   3                              WriteRTC();
 168   3                              DisplayRTC();
 169   3                      }
 170   2                      if(KeyCode == 20)   //minute -1
 171   2                      {
 172   3                              second = 0;
 173   3                              if(--minute >= 60)  minute = 59;
 174   3                              WriteRTC();
 175   3                              DisplayRTC();
 176   3                      }
 177   2      
