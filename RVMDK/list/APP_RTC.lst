 275          void IO_KeyScan(void)    //50ms call
 276          {
 277   1          u8  j;
 278   1      
 279   1          j = IO_KeyState1;   //БЃДцЩЯвЛДЮзДЬЌ
 280   1      
 281   1          P0 = 0xf0;  //XЕЭЃЌЖСY
 282   1          IO_KeyDelay();
 283   1          IO_KeyState1 = P0 & 0xf0;
 284   1      
 285   1          P0 = 0x0f;  //YЕЭЃЌЖСX
 286   1          IO_KeyDelay();
 287   1          IO_KeyState1 |= (P0 & 0x0f);
 288   1          IO_KeyState1 ^= 0xff;   //ШЁЗД
 289   1          
 290   1          if(j == IO_KeyState1)   //СЌајСНДЮЖСЯрЕШ
 291   1          {
 292   2              j = IO_KeyState;
 293   2              IO_KeyState = IO_KeyState1;
 294   2              if(IO_KeyState != 0)    //гаМќАДЯТ
 295   2              {
 296   3                  F0 = 0;
 297   3                  if(j == 0)  F0 = 1; //ЕквЛДЮАДЯТ
 298   3                  else if(j == IO_KeyState)
 299   3                  {
 300   4                      if(++IO_KeyHoldCnt >= 20)   //1УыКѓжиМќ
 301   4                      {
C51 COMPILER V9.59.0.0   APP_RTC                                                           07/12/2025 10:37:57 PAGE 6   

 302   5                          IO_KeyHoldCnt = 18;
 303   5                          F0 = 1;
 304   5                      }
 305   4                  }
 306   3                  if(F0)
 307   3                  {
 308   4                      j = T_KeyTable[IO_KeyState >> 4];
 309   4                      if((j != 0) && (T_KeyTable[IO_KeyState& 0x0f] != 0)) 
 310   4                          KeyCode = (j - 1) * 4 + T_KeyTable[IO_KeyState & 0x0f] + 16;    //МЦЫуМќТыЃЌ17~32
 311   4                  }
 312   3              }
 313   2              else    IO_KeyHoldCnt = 0;
 314   2          }
 315   1          P0 = 0xff;
 316   1      }


