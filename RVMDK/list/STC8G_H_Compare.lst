  15          //========================================================================
  16          // КЏЪ§:void    CMP_Inilize(CMP_InitDefine *CMPx)
  17          // УшЪі: БШНЯЦїГѕЪМЛЏГЬађ.
  18          // ВЮЪ§: CMPx: НсЙЙВЮЪ§,ЧыВЮПМcompare.hРяЕФЖЈвх.
  19          // ЗЕЛи: none.
  20          // АцБО: V1.0, 2012-10-22
  21          //========================================================================
  22          void    CMP_Inilize(CMP_InitDefine *CMPx)
  23          {
  24   1              CMPCR1 &= 0x30;
  25   1              CMPCR2 = CMPx->CMP_OutDelayDuty & 0x3f;                                                                         //БШНЯНсЙћБфЛЏбгЪБжмЦкЪ§, 0~63
  26   1              if(CMPx->CMP_EN == ENABLE)                              CMPCR1 |= CMPEN;                                //дЪаэБШНЯЦї            ENABLE,DISABLE
  27   1              if(CMPx->CMP_P_Select  == CMP_P_ADC)    CMPCR1 |= PIS;                  //БШНЯЦїЪфШые§МЋбЁдё, CMP_P_P37: бЁдёP3.7зіе§ЪфШы, 
             -CMP_P_ADC: гЩADCФЃФтЪфШыЖЫзіе§ЪфШы.
  28   1              if(CMPx->CMP_N_Select  == CMP_N_P36)    CMPCR1 |= NIS;                  //БШНЯЦїЪфШыИКМЋбЁдё, CMP_N_GAP: бЁдёФкВПBandGapО­Й
             -§OPКѓЕФЕчбЙзіИКЪфШы, CMP_N_P36: бЁдёP3.6зіИКЪфШы.
  29   1              if(CMPx->CMP_Outpt_En == ENABLE)                CMPCR1 |= CMPOE;                        //дЪаэБШНЯНсЙћЪфГіЕНP3.4/P4.1,   ENABLE,DISABLE
  30   1              if(CMPx->CMP_InvCMPO     == ENABLE)             CMPCR2 |= INVCMPO;      //БШНЯЦїЪфГіШЁЗД,       ENABLE,DISABLE
  31   1              if(CMPx->CMP_100nsFilter == DISABLE)    CMPCR2 |= DISFLT;               //ФкВП0.1uFТЫВЈ,        ENABLE,DISABLE
  32   1      }


